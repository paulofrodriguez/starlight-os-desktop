[Desktop Entry]
Type=Application
Version=1.0
Name=Install System
GenericName=System Installer
Comment=Use the Starlight OS installer entry instead
TryExec=/usr/local/bin/starlight-launch-installer
Exec=/usr/local/bin/starlight-launch-installer
Icon=system-software-install
Terminal=false
StartupNotify=true
Categories=System;
NoDisplay=true
X-AppStream-Ignore=true
