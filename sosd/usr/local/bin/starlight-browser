#!/usr/bin/env bash
set -Eeuo pipefail

if command -v chromium >/dev/null 2>&1; then
    exec chromium "$@"
fi

if command -v flatpak >/dev/null 2>&1 &&
    flatpak info --system org.chromium.Chromium >/dev/null 2>&1
then
    exec flatpak run org.chromium.Chromium "$@"
fi

if command -v firefox-esr >/dev/null 2>&1; then
    exec firefox-esr "$@"
fi

echo "No usable web browser is installed." >&2
exit 1
