#!/usr/bin/env bash
set -Eeuo pipefail

readonly LOG_FILE=/tmp/starlight-installer.log
readonly RUNNER=/usr/local/sbin/starlight-run-installer

notify_failure() {
    local message="$1"

    if command -v zenity >/dev/null 2>&1 && [[ -n "${DISPLAY:-}" ]]; then
        zenity --error \
            --title="Install Starlight OS" \
            --text="${message}\n\nLog: ${LOG_FILE}" >/dev/null 2>&1 || true
    fi
}

{
    printf '\n[%s] Starting Starlight OS installer launcher\n' \
        "$(date --iso-8601=seconds)"
    printf 'user=%s display=%s session=%s\n' \
        "$(id -un)" "${DISPLAY:-}" "${XDG_SESSION_TYPE:-}"
    printf 'runner=%s\n' "${RUNNER}"
} >>"${LOG_FILE}" 2>&1

if [[ ! -x "${RUNNER}" ]]; then
    echo "Installer runner is missing or not executable: ${RUNNER}" >>"${LOG_FILE}"
    notify_failure "The Starlight OS installer runner is not available."
    exit 1
fi

if pkexec "${RUNNER}" >>"${LOG_FILE}" 2>&1; then
    exit 0
fi

status=$?
echo "Installer exited with status ${status}." >>"${LOG_FILE}"
notify_failure "The Starlight OS installer did not start."
exit "${status}"
