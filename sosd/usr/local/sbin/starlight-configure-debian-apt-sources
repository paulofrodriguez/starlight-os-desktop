#!/usr/bin/env bash
set -Eeuo pipefail

readonly SOURCE_TEMPLATE=/usr/share/starlight/sources.list
readonly TARGET_SOURCE=/etc/apt/sources.list

if [[ ! -s "${SOURCE_TEMPLATE}" ]]; then
    echo "Missing Starlight Debian APT source template: ${SOURCE_TEMPLATE}" >&2
    exit 1
fi

if grep -Eqs '^[[:space:]]*deb[[:space:]]+cdrom:' "${SOURCE_TEMPLATE}"; then
    echo "The Starlight Debian APT source template must not use cdrom sources." >&2
    exit 1
fi

install -d -m 0755 /etc/apt /etc/apt/sources.list.d
install -m 0644 "${SOURCE_TEMPLATE}" "${TARGET_SOURCE}"

rm -f \
    /etc/apt/sources.list.d/starlight.sources.list \
    /etc/apt/sources.list.d/starlight-security.list \
    /etc/apt/sources.list.d/starlight-debian.sources

if grep -RhsE '^[[:space:]]*deb[[:space:]]+cdrom:' \
    /etc/apt/sources.list /etc/apt/sources.list.d
then
    echo "cdrom APT sources must not be active in the final image." >&2
    exit 1
fi

if ! grep -RhsE '^[[:space:]]*deb[[:space:]]+https://deb\.debian\.org/debian[[:space:]]+' \
    /etc/apt/sources.list /etc/apt/sources.list.d >/dev/null
then
    echo "The final image must have an active online Debian archive source." >&2
    exit 1
fi

if ! grep -RhsE '^[[:space:]]*deb[[:space:]]+https://security\.debian\.org/debian-security[[:space:]]+' \
    /etc/apt/sources.list /etc/apt/sources.list.d >/dev/null
then
    echo "The final image must have an active online Debian security source." >&2
    exit 1
fi
