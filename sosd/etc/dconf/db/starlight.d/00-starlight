[org/gnome/desktop/interface]
accent-color='yellow'
color-scheme='prefer-dark'
gtk-theme='Adwaita-dark'
icon-theme='Starlight-Colloid-Yellow-Dark'
monospace-font-name='JetBrainsMono Nerd Font 11'

[org/gnome/desktop/background]
picture-uri='file:///usr/share/backgrounds/starlight/starlight-wallpaper.png'
picture-uri-dark='file:///usr/share/backgrounds/starlight/starlight-wallpaper.png'
picture-options='zoom'

[org/gnome/desktop/screensaver]
picture-uri='file:///usr/share/backgrounds/starlight/starlight-wallpaper.png'
picture-options='zoom'

[org/gnome/desktop/default-applications/terminal]
exec='ptyxis'
exec-arg=''

[org/gnome/shell]
disable-user-extensions=false
enabled-extensions=['blur-my-shell@aunetx', 'dash-to-dock@micxgx.gmail.com', 'starlight-clock-right@starlightbrasil.com']
favorite-apps=['chromium.desktop', 'org.gnome.Nautilus.desktop', 'org.gnome.Ptyxis.desktop', 'org.gnome.Software.desktop', 'starlight-install.desktop']

# Dash to Dock owns the desktop dock appearance. Keep it as a floating,
# translucent navy surface instead of inheriting the grey upstream fallback.
[org/gnome/shell/extensions/dash-to-dock]
dock-position='BOTTOM'
extend-height=false
dash-max-icon-size=48
custom-theme-shrink=false
custom-background-color=true
background-color='#07182b'
transparency-mode='FIXED'
background-opacity=0.74
custom-theme-customize-running-dots=true
custom-theme-running-dots-color='#f3c653'
custom-theme-running-dots-border-color='#c89b3c'
running-indicator-style='DASHES'
